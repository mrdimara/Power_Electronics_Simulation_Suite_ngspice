.title KiCad schematic
.include "./edt01.sub"
.model __D1 D
.model __D2 D
Ra1 Net-_C1-Pad1_ Net-_C1-Pad2_ 100k
C1 Net-_C1-Pad1_ Net-_C1-Pad2_ 100u
Vse1 Net-_C1-Pad1_ 0 DC 10 
XxSW1 Net-_C1-Pad1_ /sw1 /g1 power_sw
XBDGE1 Net-_Vip1-Pad2_ Net-_C1-Pad2_ Net-_Vid1-Pad1_ /r Net-_Vid2-Pad1_ xfmbdge Params: Np = 10 Ns = 20 C = 100u
Vid2 Net-_Vid2-Pad1_ Net-_D2-A_ DC 0 
L1 /p /o 1m
D1 Net-_D1-A_ /p __D1
D2 Net-_D2-A_ /p __D2
R3 /o /r 10
C3 /o /r 100u
Vid1 Net-_Vid1-Pad1_ Net-_D1-A_ DC 0 
Vip1 /sw1 Net-_Vip1-Pad2_ DC 0 
Rb1 Net-_C1-Pad2_ 0 100k
XxSW2 /sw1 0 /g3 power_sw
C2 Net-_C1-Pad2_ 0 100u
XPWM_B1 Net-_V5-Pad1_ /g1 /g2 /g3 /g4 PWMbridge fs=10000
V5 Net-_V5-Pad1_ 0 DC -0.5 
.tran 0.1us 30ms
.print tran V(Net-_C1-Pad1_) V(/p) V(/o) V(Net-_Vid2-Pad1_) I(L1)
.end
